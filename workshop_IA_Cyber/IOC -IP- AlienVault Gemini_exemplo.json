    {
      "parameters": {
        "jsCode": "let output = \"\";\n\nconst items = $input.all();\n\nfor (const item of items) {\n\n  const result = item.json;\n\n  const ip = result.indicator || result.ip || \"N/A\";\n  const pulses = result.pulse_info?.pulses || [];\n\n  output += `==============================\\n`;\n  output += `IOC REPORT (AlienVault OTX)\\n`;\n  output += `IP: ${ip}\\n`;\n  output += `Pulse count: ${result.pulse_info?.count || 0}\\n\\n`;\n\n  if (pulses.length === 0) {\n    output += `No pulses available\\n`;\n  } else {\n\n    pulses.forEach((pulse, index) => {\n      output += `--- Pulse ${index + 1} ---\\n`;\n      output += `Name: ${pulse.name || \"N/A\"}\\n`;\n      output += `Description: ${pulse.description || \"N/A\"}\\n`;\n      output += `Tags: ${(pulse.tags || []).join(\", \") || \"N/A\"}\\n`;\n      output += `TLP: ${pulse.TLP || \"N/A\"}\\n`;\n      output += `----------------------\\n`;\n    });\n  }\n\n  output += `==============================\\n\\n`;\n}\n\nreturn [\n  {\n    json: {\n      text: output.trim()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
