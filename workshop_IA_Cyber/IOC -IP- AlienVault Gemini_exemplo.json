    {
      "parameters": {
        "jsCode": "const result = {\n  ioc: null,\n  alienvault: null,\n  virustotal: null,\n};\n\n// percorre todos os inputs disponíveis\nfor (const item of items) {\n  if (item.json.source === \"alienvault\") {\n    result.alienvault = item.json;\n    result.ioc = item.json.ioc;\n  }\n\n  if (item.json.source === \"virustotal\") {\n    result.virustotal = item.json;\n    result.ioc = item.json.ioc;\n  }\n}\n\nreturn [{ json: result }];"
      },
